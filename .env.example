# Core
BOTKA_BOT_TOKEN=replace-me
BOTKA_BOOTSTRAP_RESIDENT_IDS=1,2,3

# Database
BOTKA_DATABASE_URL=sqlite+aiosqlite:////data/botka.db

# Shopping list thread
BOTKA_SHOPPING_CHAT_ID=-1001234567890
BOTKA_SHOPPING_TOPIC_ID=

# Borrowed items thread
BOTKA_BORROWED_CHAT_ID=-1001234567890
BOTKA_BORROWED_TOPIC_ID=

# Pins channel
BOTKA_PINS_CHAT_ID=-1001234567890
BOTKA_PINS_TRACKED_CHAT_IDS=-1001234567890,-1002345678901

# usbutler
BOTKA_USBUTLER_BASE_URL=http://10.0.24.34:8000
BOTKA_USBUTLER_TOKEN=replace-me
BOTKA_USBUTLER_TIMEOUT_SECONDS=5

# Google Gemini (used by borrowed-items detector)
BOTKA_GEMINI_API_KEY=replace-me
BOTKA_GEMINI_MODEL=gemini-2.0-flash
BOTKA_GEMINI_TIMEOUT_SECONDS=10

# MAC tracker
BOTKA_MAC_TRACKER_BASE_URL=https://your-domain.example
BOTKA_MAC_TRACKER_BIND_HOST=0.0.0.0
BOTKA_MAC_TRACKER_BIND_PORT=1818

# Poll frequency in seconds
BOTKA_MAC_TRACKER_POLL_SECONDS=30
BOTKA_MAC_TRACKER_JWT_SECRET=replace-me
BOTKA_MAC_TRACKER_JWT_TTL_SECONDS=900
BOTKA_MAC_TRACKER_ALLOWED_SUBNETS=10.0.16.0/21,10.0.32.0/21
BOTKA_MAC_TRACKER_SUBNET_WARNING_TEXT=Warning! Your current IP address is not in the allowed subnets. Connect to <b>F0RTHSP4CE</b> or <b>F0RTHSP4CE-GUEST</b> wifi for this.
BOTKA_MAC_TRACKER_NOTIFY_CHAT_ID=-1001234567890
BOTKA_MAC_TRACKER_NOTIFY_TOPIC_ID=

# Planka
BOTKA_PLANKA_BASE_URL=http://localhost:3000
BOTKA_PLANKA_USERNAME_OR_EMAIL=admin@example.com
BOTKA_PLANKA_PASSWORD=replace-me
BOTKA_PLANKA_BOARD_NAME=TASKS
# Board ID (alternative to board name; takes precedence if set)
BOTKA_PLANKA_BOARD_ID=
BOTKA_PLANKA_POLL_INTERVAL_SECONDS=5
BOTKA_PLANKA_REQUEST_TIMEOUT_SECONDS=10
# Comma-separated chat_id or chat_id:thread_id pairs to receive notifications
BOTKA_PLANKA_NOTIFICATION_CHAT_IDS=-1001234567890,-1001234567890:42
BOTKA_PLANKA_CARD_TYPE=project
BOTKA_PLANKA_TODO_LIST_ID=
BOTKA_PLANKA_DOING_LIST_ID=
BOTKA_PLANKA_DONE_LIST_ID=

# Mikrotik REST API
BOTKA_MIKROTIK_BASE_URL=https://10.0.0.1
BOTKA_MIKROTIK_USERNAME=api-user
BOTKA_MIKROTIK_PASSWORD=replace-me
BOTKA_MIKROTIK_TIMEOUT_SECONDS=5
BOTKA_MIKROTIK_VERIFY_TLS=false

# Refinance integration
# Base URL of the Refinance API (no trailing slash)
BOTKA_REFINANCE_API_URL=https://refinance-api.f0rth.space
# Shared JWT signing secret — must match REFINANCE_SECRET_KEY in refinance .env
BOTKA_REFINANCE_SECRET_KEY=replace-me
# Entity ID that botka uses as system actor for entity lookups
BOTKA_REFINANCE_BOT_ENTITY_ID=1

# periodic tasks
BOTKA_TIMEZONE=UTC
BOTKA_POLLS_MAINTENANCE_INTERVAL_SECONDS=3600
BOTKA_POLLS_DEFAULT_CLOSE_HOURS=156
BOTKA_DECISIONS_CHAT_ID=-1001234567890
BOTKA_DECISIONS_TOPIC_ID=
BOTKA_MEETING_CHAT_ID=-1001234567890
BOTKA_MEETING_TOPIC_ID=
BOTKA_HEARTBEAT_CHAT_ID=-1001234567890
BOTKA_HEARTBEAT_TOPIC_ID=
BOTKA_GOOD_MORNING_CHAT_ID=-1001234567890
BOTKA_GOOD_MORNING_TOPIC_ID=
BOTKA_GOOD_MORNING_CITY=Tbilisi
BOTKA_GOOD_MORNING_PHOTO_URLS=http://example.com/photo1.jpg,http://example.com/photo2.jpg

# UPS acidmaid
BOTKA_UPS_BASE_URL=http://acidmaid.local
BOTKA_UPS_TIMEOUT_SECONDS=5
BOTKA_UPS_REPORT_CHAT_ID=-1001234567890
BOTKA_UPS_REPORT_TOPIC_ID=
BOTKA_UPS_REPORT_INTERVAL_SECONDS=600
BOTKA_UPS_CHECK_INTERVAL_SECONDS=30

# fridge
BOTKA_FRIDGE_POS_URL=http://fridge-pos.local
BOTKA_FRIDGE_POS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Bambu Lab printers (LAN mode)
# JSON array of printer objects; omit or leave empty to disable
BOTKA_BAMBU_PRINTERS='[{"name":"X1C","ip":"192.168.1.10","serial":"01S00C000000000","access_code":"12345678"}]'
# Seconds to wait for a camera frame before giving up
BOTKA_BAMBU_CAMERA_TIMEOUT_SECONDS=10.0

# ask to visit
BOTKA_VISIT_REQUEST_CHAT_ID=-1001234567890
BOTKA_VISIT_REQUEST_TOPIC_ID=
